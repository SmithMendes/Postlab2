<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard</title>
    <!-- Use Google Fonts for modern typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Link the new styling -->
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <div class="dashboard-container">
        <!-- rendered by EJS -->

        <main>
            <div class="card">
                <div class="card-header">
                    <!-- Show the first letter of their name -->
                    <div class="avatar">
                        <%= student.name.charAt(0) %>
                    </div>
                    <div>
                        <h2>
                            <%= student.name %>
                        </h2>
                        <span class="badge">
                            <%= student.status %>
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="info-row">
                        <span class="label">Branch</span>
                        <span class="value">
                            <%= student.branch %>
                        </span>
                    </div>
                    <div class="info-row">
                        <span class="label">Year</span>
                        <span class="value">
                            <%= student.year %>
                        </span>
                    </div>
                    <div class="info-row">
                        <span class="label">GPA</span>
                        <span class="value">
                            <%= student.gpa.toFixed(1) %>
                        </span>
                    </div>
                </div>
                <div class="rendered-by">
                    Rendered by EJS
                </div>
            </div>
        </main>
    </div>
</body>

</html>
